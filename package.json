{
  "name": "wjs-vue2-components",
  "version": "1.0.0",
  "description": "Vue2 组件库 - 工作中封装的业务组件和第三方库整理",
  "author": "wjs",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --config build/webpack.dev.conf.js --open",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config build/webpack.prod.conf.js",
    "build:lib": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config build/webpack.lib.conf.js"
  },
  "dependencies": {
    "vue": "^2.6.14",
    "vue-router": "^3.5.2",
    "element-ui": "^2.15.6",
    "echarts": "^4.9.0"
  },
  "devDependencies": {
    "webpack": "^4.46.0",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.3",
    "vue-loader": "^15.9.8",
    "vue-template-compiler": "^2.6.14",
    "babel-loader": "^8.2.3",
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.0",
    "css-loader": "^5.2.7",
    "style-loader": "^2.0.0",
    "file-loader": "^6.2.0",
    "url-loader": "^4.1.1",
    "html-webpack-plugin": "^4.5.2",
    "clean-webpack-plugin": "^3.0.0",
    "mini-css-extract-plugin": "^1.6.2",
    "sass-loader": "^10.2.0",
    "sass": "^1.69.0",
    "cross-env": "^7.0.3",
    "webpack-merge": "^4.2.2"
  }
